{
  "expo": {
    "name": "Skyline Group",
    "slug": "skyline-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skyline-mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skylinegroup.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for scanning QR codes",
        "NSPhotoLibraryUsageDescription": "Used to share product images",
        "CFBundleLocalizations": ["ar", "en", "tr"],
        "CFBundleDevelopmentRegion": "ar"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1B3A6B"
      },
      "package": "com.skylinegroup.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_PHONE_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "skyline-group-mobile"
      }
    }
  }
}
